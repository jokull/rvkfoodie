---
import Layout from "../../layouts/Layout.astro";
import VenueCard from "../../components/VenueCard.astro";
import Paywall from "../../components/Paywall.astro";
import RestaurantCallout from "../../components/RestaurantCallout.astro";
import { getGuideBySlug, getAllGuides, getAllEditorials, type SectionBlock, type TextBlock } from "../../lib/cms";
import { dastToHtml } from "../../lib/dast";
import { env } from "cloudflare:workers";

const { slug } = Astro.params;

// Parallelize all independent fetches
const [guide, allGuides, editorials, sessionProducts, unlockToken] = await Promise.all([
  getGuideBySlug(slug!),
  getAllGuides(),
  getAllEditorials(),
  Astro.session?.get("unlockedProducts").catch(() => null) as Promise<string[] | null>,
  Astro.session?.get("unlockToken").catch(() => null) as Promise<string | null>,
]);
if (!guide) return Astro.redirect("/");

const otherGuides = allGuides.filter((g) => g.slug !== guide.slug);
let unlockedProducts: string[] = sessionProducts ?? [];
if (unlockToken && !unlockedProducts.includes(guide.gumroadProductId)) {
  const kv = env.PURCHASES;
  const raw = await kv.get(`unlock:${unlockToken}`);
  if (raw) {
    const purchase = JSON.parse(raw) as { productIds: string[] };
    for (const pid of purchase.productIds) {
      if (!unlockedProducts.includes(pid)) unlockedProducts.push(pid);
    }
    await Astro.session?.set("unlockedProducts", unlockedProducts);
    await kv.delete(`unlock:${unlockToken}`);
    await Astro.session?.set("unlockToken", null);
  }
}

const unlocked = unlockedProducts.includes(guide.gumroadProductId);
const error = Astro.url.searchParams.get("error");
const prefillKey = Astro.url.searchParams.get("key") ?? "";
const pending = Astro.url.searchParams.get("pending") === "true";

let totalHidden = 0;
for (const block of guide.content) {
  if (block.blockType === "section") {
    totalHidden += (block as SectionBlock).venues.filter((v) => !v.isFree).length;
  }
}

const totalVenues = guide.content.reduce((n, b) =>
  b.blockType === "section" ? n + (b as SectionBlock).venues.length : n, 0);

const introHtml = guide.intro ? dastToHtml(guide.intro) : "";

// Find blog posts that mention venues from this guide (editorials already fetched above)
const venueNames = guide.content.flatMap((b) =>
  b.blockType === "section" ? (b as SectionBlock).venues.map((v) => v.name.toLowerCase().replace(/[!?]/g, "")) : []
);
const relatedPosts = editorials.filter((p) => {
  const text = `${p.title} ${p.excerpt}`.toLowerCase();
  return venueNames.some((vn) => text.includes(vn));
}).slice(0, 3);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: guide.title,
  description: guide.description,
  url: `https://www.rvkfoodie.is/guides/${guide.slug}`,
  offers: { "@type": "Offer", price: guide.price, priceCurrency: "USD", url: guide.gumroadUrl, availability: "https://schema.org/InStock" },
  brand: { "@type": "Organization", name: "Reykjavík Foodie", url: "https://www.rvkfoodie.is" },
  ...(totalVenues > 0 ? { keywords: `Reykjavík restaurants, Iceland food guide, ${totalVenues} venues` } : {}),
};
---

<Layout title={`${guide.title} — Reykjavík Foodie`} description={guide.description} canonicalPath={`/guides/${guide.slug}`} ogImage={`/og-${guide.slug}.jpg`} jsonLd={jsonLd}>
  <a href="/" class="text-tiny text-ink-light hover:text-blue transition-colors mb-8 inline-block">&larr; All guides</a>

  <h1 class="font-display text-huge leading-huge mb-2">{guide.title}</h1>
  <p class="text-tiny text-ink-light mb-8">{guide.subtitle}</p>

  {introHtml && (
    <div class="mb-12 prose-intro">
      <Fragment set:html={introHtml} />
    </div>
  )}

  {guide.content.map((block) => {
    if (block.blockType === "section") {
      const section = block as SectionBlock;
      const freeVenues = section.venues.filter((v) => v.isFree);
      const gatedVenues = section.venues.filter((v) => !v.isFree);
      return (
        <section class="mb-12">
          <h2 class="font-display text-[1.75rem] leading-tight mb-2 pb-4 border-b border-ink/10">{section.title}</h2>
          {freeVenues.map((venue) => <VenueCard {...venue} />)}
          {unlocked
            ? gatedVenues.map((venue) => <VenueCard {...venue} />)
            : gatedVenues.length > 0
              ? <p class="py-6 text-ink-light text-tiny italic">+{gatedVenues.length} more in the full guide</p>
              : null}
        </section>
      );
    }
    if (block.blockType === "textBlock") {
      const textBlock = block as TextBlock;
      if (!unlocked && !textBlock.isFree) return null;
      const html = dastToHtml(textBlock.content);
      return (
        <section class="mb-12 prose-custom">
          {textBlock.heading && <h2 class="font-display text-[1.75rem] leading-tight mb-4 pb-4 border-b border-ink/10">{textBlock.heading}</h2>}
          <Fragment set:html={html} />
        </section>
      );
    }
    return null;
  })}

  {!unlocked && totalHidden > 0 && (
    <Paywall gumroadUrl={guide.gumroadUrl} price={guide.price} hiddenCount={totalHidden} slug={guide.slug} productId={guide.gumroadProductId} prefillKey={prefillKey} error={error === "invalid_key" ? "invalid" : undefined} pending={pending} />
  )}

  {unlocked && guide.googleMapsUrl && (
    <div class="mb-12">
      <h2 class="font-display text-[1.75rem] leading-tight mb-4 pb-4 border-b border-ink/10">Google Maps</h2>
      <a href={guide.googleMapsUrl} target="_blank" rel="noopener" class="inline-block bg-blue text-white font-medium px-6 py-2.5 rounded-full text-tiny hover:opacity-90 transition-opacity">Open pin list in Google Maps &nearr;</a>
    </div>
  )}

  {otherGuides.length > 0 && (
    <aside class="mt-16 border-t border-ink/10 pt-8">
      <h2 class="font-display text-[1.5rem] leading-tight mb-4">More guides</h2>
      <div class="flex flex-wrap gap-3">
        {otherGuides.map((g) => (
          <a href={`/guides/${g.slug}`} class="border border-ink/10 rounded-full px-4 py-1.5 text-tiny hover:border-blue hover:text-blue transition-colors">{g.title}</a>
        ))}
      </div>
      <p class="mt-4 text-tiny text-ink-light"><a href="/about" class="text-blue hover:opacity-80 transition-opacity">About the author &rarr;</a></p>
    </aside>
  )}

  {relatedPosts.length > 0 && (
    <aside class="mt-12 border-t border-ink/10 pt-8">
      <h2 class="font-display text-[1.5rem] leading-tight mb-4">From the blog</h2>
      <div class="space-y-4">
        {relatedPosts.map((p) => (
          <a href={`/blog/${p.slug}`} class="block border border-ink/10 rounded-xl p-5 hover:border-ink/25 transition-colors group">
            <p class="text-tiny text-ink-light mb-1">{new Date(p.date).toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" })}</p>
            <h3 class="font-display text-[1.25rem] leading-tight group-hover:text-blue transition-colors">{p.title}</h3>
            <p class="text-tiny text-ink-light mt-1 line-clamp-2">{p.excerpt}</p>
          </a>
        ))}
      </div>
    </aside>
  )}

  <div class="mt-12"><RestaurantCallout /></div>
</Layout>

<style>
  .prose-intro :global(p) { margin-bottom: 1rem; color: var(--color-ink-light); }
  .prose-intro :global(h3) { font-weight: 500; margin-top: 1.5rem; margin-bottom: 0.5rem; color: var(--color-ink); }
  .prose-intro :global(ul) { list-style: disc; padding-left: 1.25rem; color: var(--color-ink-light); }
  .prose-intro :global(li) { margin-bottom: 0.25rem; }
  .prose-intro :global(strong) { font-weight: 500; color: var(--color-ink); }
  .prose-custom :global(p) { margin-bottom: 1rem; }
  .prose-custom :global(strong) { font-weight: 500; }
</style>
