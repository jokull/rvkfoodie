---
import Layout from "../layouts/Layout.astro";
import RestaurantCallout from "../components/RestaurantCallout.astro";
import { getAllGuides, getAboutPage } from "../lib/cms";
import { dastToHtml } from "../lib/dast";

const guides = await getAllGuides();
const about = await getAboutPage();
const bioHtml = about.bio ? dastToHtml(about.bio) : "";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Reykjavík Foodie",
  url: "https://www.rvkfoodie.is/about",
  sameAs: ["https://instagram.com/rvkfoodie"],
};
---

<Layout title={`${about.title} — Reykjavík Foodie`} description={about.metaDescription} canonicalPath="/about" jsonLd={jsonLd}>
  <h1 class="font-display text-huge leading-huge mb-8">{about.title}</h1>

  <div class="mb-10">
    <img src="/about.jpg" alt="Reykjavík Foodie" class="w-48 rounded-2xl object-cover shadow-2xl shadow-ink/20" loading="eager" />
  </div>

  <div class="space-y-6 mb-16 prose-about">
    <Fragment set:html={bioHtml} />
  </div>

  <section class="border-t border-ink/10 pt-8">
    <h2 class="font-display text-[1.75rem] leading-tight mb-6">The guides</h2>
    <div class="space-y-4">
      {guides.map((guide) => (
        <a href={`/guides/${guide.slug}`} class="flex items-center justify-between border border-ink/10 rounded-xl p-5 hover:border-ink/25 transition-colors group">
          <div>
            <h3 class="font-display text-[1.25rem] leading-tight group-hover:text-blue transition-colors">{guide.title}</h3>
            <p class="text-tiny text-ink-light mt-1">{guide.subtitle}</p>
          </div>
          <span class="text-tiny text-ink-light">${guide.price}</span>
        </a>
      ))}
    </div>
  </section>

  <div class="mt-12"><RestaurantCallout /></div>
</Layout>

<style>
  .prose-about :global(p) { margin-bottom: 1.5rem; }
  .prose-about :global(a) { color: var(--color-blue); }
  .prose-about :global(a:hover) { opacity: 0.8; }
  .prose-about :global(p:last-child) { font-size: 0.75rem; color: var(--color-ink-light); }
</style>
