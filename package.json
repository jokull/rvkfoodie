{
  "name": "rvkfoodie",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "deploy": "wrangler d1 migrations apply rvkfoodie-cms-v2 --remote && astro build && wrangler deploy",
    "lint": "oxlint --config oxlintrc.json src/",
    "typecheck": "tsc --noEmit",
    "db:migrate": "wrangler d1 migrations apply rvkfoodie-cms-v2 --local",
    "db:migrate:remote": "wrangler d1 migrations apply rvkfoodie-cms-v2 --remote"
  },
  "dependencies": {
    "@0no-co/graphqlsp": "^1.15.2",
    "@astrojs/cloudflare": "^13.0.0",
    "@datocms/astro": "^0.6.11",
    "agent-cms": "file:../agent-cms",
    "astro": "^6.0.0",
    "datocms-structured-text-to-html-string": "^5.1.7",
    "datocms-structured-text-utils": "^5.1.7",
    "gql.tada": "^1.9.0",
    "graphql": "^16.13.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "lucide-static": "^0.577.0",
    "oxlint": "^1.56.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.0.0"
  }
}
