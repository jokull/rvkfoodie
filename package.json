{
  "name": "rvkfoodie",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "deploy": "wrangler d1 migrations apply rvkfoodie-cms-v4b --remote && vite build && wrangler deploy",
    "check": "oxlint --config oxlintrc.json --type-aware --type-check app/ lib/",
    "db:migrate": "wrangler d1 migrations apply rvkfoodie-cms-v4b --local",
    "db:migrate:remote": "wrangler d1 migrations apply rvkfoodie-cms-v4b --remote"
  },
  "dependencies": {
    "@0no-co/graphqlsp": "^1.15.2",
"@cloudflare/vite-plugin": "^1.30.0",
    "@vitejs/plugin-rsc": "^0.5.21",
    "agent-cms": "file:../agent-cms",
    "datocms-structured-text-to-html-string": "^5.1.7",
    "datocms-structured-text-utils": "^5.1.7",
    "gql.tada": "^1.9.0",
    "graphql": "^16.13.1",
    "nanoid": "^5.1.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vinext": "^0.0.33"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260321.1",
    "lucide-static": "^0.577.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "wrangler": "^4.76.0"
  },
  "pnpm": {
