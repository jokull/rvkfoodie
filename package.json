{
  "name": "rvkfoodie",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "deploy": "wrangler d1 migrations apply rvkfoodie-cms-v2 --remote && vite build && wrangler deploy",
    "lint": "oxlint --config oxlintrc.json app/ lib/",
    "typecheck": "tsc --noEmit",
    "db:migrate": "wrangler d1 migrations apply rvkfoodie-cms-v2 --local",
    "db:migrate:remote": "wrangler d1 migrations apply rvkfoodie-cms-v2 --remote"
  },
  "dependencies": {
    "@0no-co/graphqlsp": "^1.15.2",
    "@cloudflare/vite-plugin": "^1.0.0",
    "@vitejs/plugin-rsc": "^0.5.21",
    "@agent-cms/visual-edit": "link:../agent-cms/packages/visual-edit",
    "@agent-cms/visual-edit-react": "link:../agent-cms/packages/visual-edit-react",
    "agent-cms": "file:../agent-cms",
    "datocms-structured-text-to-html-string": "^5.1.7",
    "datocms-structured-text-utils": "^5.1.7",
    "gql.tada": "^1.9.0",
    "graphql": "^16.13.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vinext": "^0.0.26"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "lucide-static": "^0.577.0",
    "oxlint": "^1.56.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^7.0.0",
    "wrangler": "^4.75.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd",
      "sharp",
      "@parcel/watcher",
      "msgpackr-extract"
    ]
  }
}
