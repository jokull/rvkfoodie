---
import Layout from "../layouts/Layout.astro";
import { getChangelog, type ChangelogEntry } from "../lib/payload";

const entries = await getChangelog();

const typeLabel: Record<string, string> = { added: "Added", removed: "Removed", updated: "Updated" };
const typeColor: Record<string, string> = { added: "text-green-700 bg-green-50", removed: "text-red-700 bg-red-50", updated: "text-blue bg-blue/5" };
---

<Layout title="Guide Updates — Reykjavík Foodie" description="Every update to our Reykjavík food guides, tracked." canonicalPath="/changelog">
  <h1 class="font-display text-huge leading-huge mb-4">Guide Updates</h1>
  <p class="text-ink-light mb-12">New spots, closures, menu changes — this is how we keep our guides current.</p>

  {entries.length === 0 ? (
    <div class="border border-ink/10 rounded-2xl p-8 text-center">
      <p class="text-ink-light">No changes logged yet. Check back soon.</p>
    </div>
  ) : (
    <div class="space-y-0">
      {entries.map((entry, i) => {
        const prev = entries[i - 1];
        const showDate = !prev || prev.date !== entry.date;
        const dateStr = new Date(entry.date).toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" });
        return (
          <div>
            {showDate && <p class="text-tiny text-ink-light pt-8 pb-3 first:pt-0">{dateStr}</p>}
            <div class="flex items-start gap-3 pb-4">
              <span class={`text-tiny font-medium px-2 py-0.5 rounded ${typeColor[entry.changeType] ?? ""}`}>{typeLabel[entry.changeType]}</span>
              <div class="flex-1">
                <p class="font-medium">{entry.title}</p>
                {entry.description && <p class="text-ink-light text-tiny mt-1">{entry.description}</p>}
                {entry.guide && typeof entry.guide === "object" && (
                  <a href={`/guides/${entry.guide.slug}`} class="text-tiny text-blue hover:opacity-80 transition-opacity mt-1 inline-block">{entry.guide.title} &rarr;</a>
                )}
              </div>
            </div>
          </div>
        );
      })}
    </div>
  )}
</Layout>
