---
import Layout from "../../layouts/Layout.astro";
import RestaurantCallout from "../../components/RestaurantCallout.astro";
import { getEditorialBySlug, getAllGuides } from "../../lib/payload";
import { lexicalToHtml } from "../../lib/lexical";
import { mediaUrl } from "../../lib/images";

const { slug } = Astro.params;
const post = await getEditorialBySlug(slug!);
if (!post) return Astro.redirect("/");

const allGuides = await getAllGuides();

const dateStr = new Date(post.date).toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" });
const contentHtml = lexicalToHtml(post.content);
const heroUrl = post.image ? mediaUrl(post.image.filename || post.image.url) : null;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.title,
  description: post.excerpt,
  datePublished: post.date,
  mainEntityOfPage: `https://www.rvkfoodie.is/blog/${post.slug}`,
  author: { "@type": "Person", name: "Reykjavík Foodie", url: "https://www.rvkfoodie.is/about" },
  publisher: { "@type": "Organization", name: "Reykjavík Foodie", url: "https://www.rvkfoodie.is", logo: { "@type": "ImageObject", url: "https://www.rvkfoodie.is/logo.svg" } },
  ...(heroUrl ? { image: heroUrl } : {}),
};
---

<Layout title={`${post.title} — Reykjavík Foodie`} description={post.excerpt} canonicalPath={`/blog/${post.slug}`} type="article" publishedTime={post.date} ogImage={heroUrl ?? undefined} jsonLd={jsonLd}>
  <a href="/" class="text-tiny text-ink-light hover:text-blue transition-colors mb-8 inline-block">&larr; Home</a>

  <article>
    <p class="text-tiny leading-tiny text-ink-light mb-4">{dateStr}</p>
    <h1 class="font-display text-huge leading-huge mb-10">{post.title}</h1>

    {heroUrl && (
      <div class="mb-12 rounded-2xl overflow-hidden">
        <img src={heroUrl} alt={post.image?.alt || post.title} class="w-full rounded-2xl" loading="eager" />
      </div>
    )}

    <div class="prose-custom">
      <Fragment set:html={contentHtml} />
    </div>
  </article>

  <aside class="mt-16 border-t border-ink/10 pt-8">
    <p class="text-tiny text-ink-light mb-4">Explore our guides</p>
    <div class="flex flex-wrap gap-3">
      {allGuides.map((guide) => (
        <a href={`/guides/${guide.slug}`} class="border border-ink/10 rounded-full px-4 py-1.5 text-tiny hover:border-blue hover:text-blue transition-colors">{guide.title} — ${guide.price}</a>
      ))}
    </div>
  </aside>
</Layout>

<style>
  .prose-custom :global(p) { margin-bottom: 1.25rem; }
  .prose-custom :global(strong) { font-weight: 500; }
  .prose-custom :global(h2) { font-family: "Instrument Serif", serif; font-size: clamp(2rem, 4vw, 3rem); line-height: 1.15; margin-top: 3rem; margin-bottom: 1rem; }
  .prose-custom :global(a) { color: var(--color-blue); text-decoration: underline; text-underline-offset: 2px; }
  .prose-custom :global(blockquote) { border-left: 3px solid var(--color-blue); padding-left: 1.25rem; margin: 1.5rem 0; font-style: italic; color: var(--color-ink-light); }
</style>
