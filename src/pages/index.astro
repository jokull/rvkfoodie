---
import Layout from "../layouts/Layout.astro";
import { getAllGuides, getAllEditorials, type Guide, type Editorial } from "../lib/payload";
import { mediaUrl } from "../lib/images";

const guides = await getAllGuides();
const editorials = await getAllEditorials();

const unlockedProducts: string[] =
  (await Astro.session?.get("unlockedProducts")) ?? [];

// Collect photos for collage from editorials with images
const collagePhotos = editorials
  .filter((p): p is Editorial & { image: NonNullable<Editorial["image"]> } => !!p.image)
  .slice(0, 8);

// Hand-placed — relaxed scatter from center
const collageCards = [
  { x: -280, y: 10,   rot: "-6deg",  z: 4, w: 150 },
  { x: -150, y: 100,  rot: "4deg",   z: 7, w: 135 },
  { x: -50,  y: 0,    rot: "7deg",   z: 3, w: 165 },
  { x: 60,   y: 85,   rot: "-3deg",  z: 8, w: 150 },
  { x: 140,  y: -5,   rot: "-5deg",  z: 5, w: 155 },
  { x: 260,  y: 90,   rot: "6deg",   z: 6, w: 135 },
  { x: -200, y: 190,  rot: "3deg",   z: 1, w: 120 },
  { x: 170,  y: 185,  rot: "-4deg",  z: 2, w: 125 },
];

const guideEmoji: Record<string, string> = {
  "food-guide": "🍽️",
  "bar-crawl": "🍸",
  "golden-circle": "🌋",
};


const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Reykjavík Foodie",
  url: "https://www.rvkfoodie.is",
  description: "Insider food guides for Reykjavík and beyond.",
  publisher: {
    "@type": "Organization",
    name: "Reykjavík Foodie",
    url: "https://www.rvkfoodie.is",
    sameAs: ["https://instagram.com/rvkfoodie"],
  },
};
---

<Layout
  title="Reykjavík Foodie — Local Food & Restaurant Guides"
  description="Insider food guides for Reykjavík and Iceland's Golden Circle. 20+ vetted restaurants, bars, and cafés picked by locals in the food industry. Updated for 2026."
  canonicalPath="/"
  jsonLd={jsonLd}
>
  <div class="mb-12">
    <h1 class="font-display text-huge leading-huge mb-6">
      Eat like<br /><em>someone who knows</em>
    </h1>
    <p class="text-ink-light max-w-md">
      Insider food guides for Reykjavík and beyond. Written by locals in the
      food industry — not influencers, not tourists. Updated for 2026.
    </p>
  </div>

  {/* Photo collage */}
  {collagePhotos.length > 0 && (
    <div class="relative h-80 sm:h-[22rem] mb-16 overflow-visible">
      {collagePhotos.map((photo, i) => {
        const card = collageCards[i];
        if (!card) return null;
        const imgUrl = mediaUrl(photo.image.filename || photo.image.url);
        return (
          <div
            class="absolute rounded-2xl overflow-hidden shadow-lg border-4 border-cream"
            style={`left:calc(50% + ${card.x}px);top:${card.y}px;width:${card.w}px;height:${card.w}px;margin-left:${-card.w / 2}px;transform:rotate(${card.rot});z-index:${card.z};`}
          >
            <img src={imgUrl} alt={photo.image.alt || photo.title} class="w-full h-full object-cover" loading="eager" />
          </div>
        );
      })}
    </div>
  )}

  {/* Guides */}
  <section class="mb-8">
    <h2 class="font-display text-[1.75rem] leading-tight mb-6 pb-4 border-b border-ink/10">The guides</h2>
    <div class="space-y-4">
      {guides.map((guide) => (
        <a href={`/guides/${guide.slug}`} class="block border border-ink/10 rounded-2xl overflow-hidden hover:border-ink/25 transition-colors group">
          <div class="p-8">
            <div class="flex items-start justify-between gap-4 mb-2">
              <div class="flex items-center gap-3">
                <span class="text-[2rem] leading-none">{guideEmoji[guide.slug] || "📖"}</span>
                <h3 class="font-display text-[1.75rem] leading-tight group-hover:text-blue transition-colors">{guide.title}</h3>
              </div>
              {unlockedProducts.includes(guide.gumroadProductId) ? (
                <span class="text-tiny text-blue font-medium whitespace-nowrap mt-2">Unlocked</span>
              ) : (
                <span class="text-tiny text-ink-light whitespace-nowrap mt-2">${guide.price}</span>
              )}
            </div>
            <p class="text-tiny leading-tiny text-ink-light mb-2 ml-12">{guide.subtitle}</p>
            <p class="text-ink-light ml-12">{guide.description}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <div class="border border-ink/10 rounded-2xl p-8 mb-20">
    <div class="flex items-start justify-between gap-4 mb-3">
      <h2 class="font-display text-[1.75rem] leading-tight">Reykjavík Food & Bar Bundle</h2>
      <span class="text-tiny text-ink-light whitespace-nowrap mt-1">$17</span>
    </div>
    <p class="text-ink-light mb-4">Get the Food Guide + Bar Crawl together and save.</p>
    <a href={`/api/checkout?slug=food-guide&url=${encodeURIComponent("https://rvkfoodie.gumroad.com/l/bundle")}`} class="inline-block bg-blue text-white font-medium px-6 py-2.5 rounded-full text-tiny hover:opacity-90 transition-opacity">Get the bundle — $17</a>
  </div>

  {/* Blog posts */}
  {editorials.length > 0 && (
    <section class="mb-16">
      <h2 class="font-display text-[1.75rem] leading-tight mb-6 pb-4 border-b border-ink/10">From the blog</h2>
      <div class="space-y-6">
        {editorials.map((post) => {
          const imgUrl = post.image ? mediaUrl(post.image.filename || post.image.url) : null;
          return (
            <a href={`/blog/${post.slug}`} class="flex gap-5 group items-start">
              {imgUrl && (
                <div class="w-24 h-24 sm:w-32 sm:h-32 rounded-xl overflow-hidden shrink-0">
                  <img src={imgUrl} alt={post.image?.alt || post.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
                </div>
              )}
              <div class="flex-1 min-w-0">
                <p class="text-tiny text-ink-light mb-1">{new Date(post.date).toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" })}</p>
                <h3 class="font-display text-[1.5rem] leading-tight group-hover:text-blue transition-colors mb-2">{post.title}</h3>
                <p class="text-ink-light line-clamp-2 text-tiny">{post.excerpt}</p>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  )}

  <section class="border-t border-ink/10 pt-8">
    <div class="flex items-center gap-4">
      <img src="/about.jpg" alt="Reykjavík Foodie" class="w-12 h-12 rounded-full object-cover" width="48" height="48" loading="lazy" />
      <p class="text-ink-light">Written by a local foodie living in Reykjavík. <a href="/about" class="text-blue hover:opacity-80 transition-opacity">Read more &rarr;</a></p>
    </div>
  </section>
</Layout>
