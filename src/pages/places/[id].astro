---
import Layout from "../../layouts/Layout.astro";
import Icon from "../../components/Icon.astro";
import RestaurantCallout from "../../components/RestaurantCallout.astro";
import { getAllGuides, getAllEditorials, type Venue, type SectionBlock } from "../../lib/payload";

interface VenueWithContext extends Venue {
  sectionTitle: string;
  guideSlug: string;
  guideTitle: string;
  gumroadUrl: string;
  guidePrice: number;
}

const { id } = Astro.params;
const allGuides = await getAllGuides();

let venue: VenueWithContext | null = null;
let guideVenueCount = 0;
let guideSectionNames: string[] = [];
const allVenues: VenueWithContext[] = [];

for (const guide of allGuides) {
  let venueCountForGuide = 0;
  const sectionNames: string[] = [];
  for (const block of guide.content) {
    if (block.blockType === "section") {
      const section = block as SectionBlock;
      sectionNames.push(section.title);
      venueCountForGuide += section.venues.length;
      for (const v of section.venues) {
        const ctx: VenueWithContext = {
          ...v,
          sectionTitle: section.title,
          guideSlug: guide.slug,
          guideTitle: guide.title,
          gumroadUrl: guide.gumroadUrl,
          guidePrice: guide.price,
        };
        allVenues.push(ctx);
        if (v.id === id) {
          venue = ctx;
          guideVenueCount = venueCountForGuide; // will be updated after loop
          guideSectionNames = sectionNames;
        }
      }
    }
  }
  // Update with final count if this was the matching guide
  if (venue && venue.guideSlug === guide.slug) {
    guideVenueCount = venueCountForGuide;
    guideSectionNames = sectionNames;
  }
}

if (!venue) return Astro.redirect("/");

const mapsUrl = venue.googleMapsUrl || `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(`${venue.name} ${venue.address} Iceland`)}`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Restaurant",
  name: venue.name,
  address: { "@type": "PostalAddress", streetAddress: venue.address, addressCountry: "IS" },
  description: venue.description,
};

// Only show free venues in "More in" section — don't give away paid content
const nearby = allVenues
  .filter((v) => v.id !== venue!.id && v.guideSlug === venue!.guideSlug && v.sectionTitle === venue!.sectionTitle && v.isFree)
  .slice(0, 3);

const otherSections = guideSectionNames.filter((s) => s !== venue!.sectionTitle);

// Find related blog posts that mention this venue by name
const editorials = await getAllEditorials();
const venuNameLower = venue.name.toLowerCase().replace(/[!?]/g, "");
const relatedPosts = editorials.filter((p) => {
  const text = `${p.title} ${p.excerpt}`.toLowerCase();
  return text.includes(venuNameLower) || venuNameLower.split(" ").every((w) => w.length > 3 && text.includes(w));
}).slice(0, 3);
---

<Layout title={`${venue.name} — Reykjavík Foodie`} description={venue.description.slice(0, 160)} canonicalPath={`/places/${venue.id}`} jsonLd={jsonLd}>
  <a href={`/guides/${venue.guideSlug}`} class="text-tiny text-ink-light hover:text-blue transition-colors mb-8 inline-block">&larr; {venue.guideTitle}</a>

  <article>
    <p class="text-tiny leading-tiny text-blue font-medium tracking-wide uppercase mb-3">{venue.sectionTitle}</p>
    {venue.bestOfAward && (
      <p class="text-tiny font-medium mb-3">
        {venue.grapevineUrl ? (
          <a href={venue.grapevineUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 text-blue hover:opacity-80 transition-opacity">
            <Icon name="trophy" class="w-4 h-4" />{venue.bestOfAward}
          </a>
        ) : (
          <span class="inline-flex items-center gap-1.5 text-blue"><Icon name="trophy" class="w-4 h-4" />{venue.bestOfAward}</span>
        )}
      </p>
    )}
    <h1 class="font-display text-huge leading-huge mb-2">{venue.name}</h1>
    {venue.address && <a href={mapsUrl} target="_blank" rel="noopener" class="text-tiny text-ink-light hover:text-blue transition-colors inline-block mb-4">{venue.address} &nearr;</a>}
    {venue.openingHours && <p class="text-tiny text-ink-light mb-4">{venue.openingHours}</p>}
    {venue.time && <p class="text-tiny text-ink-light mb-4">{venue.time}</p>}
    {(venue.phone || venue.website) && (
      <div class="flex gap-4 text-tiny text-ink-light mb-6">
        {venue.phone && <span>{venue.phone}</span>}
        {venue.website && <a href={venue.website.startsWith("http") ? venue.website : `https://${venue.website}`} target="_blank" rel="noopener" class="text-blue hover:opacity-80 transition-opacity">{venue.website}</a>}
      </div>
    )}
    <p class="mb-6">{venue.description}</p>
    {venue.note && <p class="text-tiny text-ink-light italic mb-8">{venue.note}</p>}

    <div class="flex flex-wrap gap-3 mb-12">
      <a href={mapsUrl} target="_blank" rel="noopener" class="inline-block border border-ink/15 rounded-full px-5 py-2 text-tiny hover:border-blue hover:text-blue transition-colors">Open in Google Maps &nearr;</a>
    </div>
  </article>

  {/* Guide upsell */}
  <div class="border border-ink/10 rounded-2xl p-8 mb-12">
    <p class="text-tiny text-blue font-medium uppercase tracking-wide mb-2">From the {venue.guideTitle}</p>
    <h2 class="font-display text-[1.75rem] leading-tight mb-3">{venue.name} is one of {guideVenueCount} hand-picked spots</h2>
    <p class="text-ink-light mb-2">
      The full guide covers {guideSectionNames.join(", ")} — every spot personally vetted by a local.
    </p>
    <p class="text-ink-light mb-6 text-tiny">Includes Google Maps pin list and regular updates when places open, close, or change.</p>
    <a href={`/guides/${venue.guideSlug}`} class="inline-block bg-blue text-white font-medium px-6 py-2.5 rounded-full text-tiny hover:opacity-90 transition-opacity">See the full guide — ${venue.guidePrice}</a>
  </div>

  {relatedPosts.length > 0 && (
    <aside class="border-t border-ink/10 pt-8 mb-8">
      <h2 class="font-display text-[1.5rem] leading-tight mb-4">From the blog</h2>
      <div class="space-y-4">
        {relatedPosts.map((p) => (
          <a href={`/blog/${p.slug}`} class="block border border-ink/10 rounded-xl p-5 hover:border-ink/25 transition-colors group">
            <p class="text-tiny text-ink-light mb-1">{new Date(p.date).toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" })}</p>
            <h3 class="font-display text-[1.25rem] leading-tight group-hover:text-blue transition-colors">{p.title}</h3>
          </a>
        ))}
      </div>
    </aside>
  )}

  {nearby.length > 0 && (
    <aside class="border-t border-ink/10 pt-8">
      <h2 class="font-display text-[1.5rem] leading-tight mb-2">Also in {venue.sectionTitle}</h2>
      <p class="text-tiny text-ink-light mb-4">Free preview from the <a href={`/guides/${venue.guideSlug}`} class="text-blue hover:opacity-80 transition-opacity">{venue.guideTitle}</a></p>
      <div class="space-y-4">
        {nearby.map((v) => (
          <a href={`/places/${v.id}`} class="block border border-ink/10 rounded-xl p-5 hover:border-ink/25 transition-colors group">
            <h3 class="font-display text-[1.25rem] leading-tight group-hover:text-blue transition-colors">{v.name}</h3>
            {v.address && <p class="text-tiny text-ink-light mt-1">{v.address}</p>}
          </a>
        ))}
      </div>
    </aside>
  )}

  <div class="mt-12"><RestaurantCallout /></div>
</Layout>
