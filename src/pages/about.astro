---
import Layout from "../layouts/Layout.astro";
import RestaurantCallout from "../components/RestaurantCallout.astro";
import { getAllGuides } from "../lib/payload";

const guides = await getAllGuides();

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Reykjavík Foodie",
  url: "https://www.rvkfoodie.is/about",
  sameAs: ["https://instagram.com/rvkfoodie"],
};
---

<Layout title="About — Reykjavík Foodie" description="A local foodie in Reykjavík writing the guides she wishes existed." canonicalPath="/about" jsonLd={jsonLd}>
  <h1 class="font-display text-huge leading-huge mb-8">About</h1>

  <div class="mb-10">
    <img src="/about.jpg" alt="Reykjavík Foodie" class="w-48 rounded-2xl object-cover shadow-2xl shadow-ink/20" loading="eager" />
  </div>

  <div class="space-y-6 mb-16">
    <p>I'm a wife and mum of two, living in the Hlíðar neighbourhood of Reykjavík. I spend an unreasonable amount of time thinking about where to eat next.</p>
    <p>I started <a href="https://instagram.com/rvkfoodie" target="_blank" rel="noopener" class="text-blue hover:opacity-80 transition-opacity">@rvkfoodie</a> because the restaurant advice out there for visitors was terrible — TripAdvisor top-tens full of tourist traps, bloggers who'd never set foot in a real neighbourhood spot, and Google results that rewarded mediocrity.</p>
    <p>These guides are my antidote. Every restaurant, café, and bar in them is a place I go to myself, often with my family. I know the chefs, I know the menus, and I know what to order. Nothing is sponsored. Nothing is paid placement. If it's in the guide, it's because I genuinely think you should eat there.</p>
    <p>The guides are updated regularly — places close, menus change, new spots open. When you buy a guide, you're getting recommendations that are current, not a snapshot from two years ago.</p>
    <p class="text-ink-light text-tiny">Questions? Suggestions? Reach me at <a href="mailto:rvkfoodie@rvkfoodie.is" class="text-blue">rvkfoodie@rvkfoodie.is</a> or DM on Instagram.</p>
  </div>

  <section class="border-t border-ink/10 pt-8">
    <h2 class="font-display text-[1.75rem] leading-tight mb-6">The guides</h2>
    <div class="space-y-4">
      {guides.map((guide) => (
        <a href={`/guides/${guide.slug}`} class="flex items-center justify-between border border-ink/10 rounded-xl p-5 hover:border-ink/25 transition-colors group">
          <div>
            <h3 class="font-display text-[1.25rem] leading-tight group-hover:text-blue transition-colors">{guide.title}</h3>
            <p class="text-tiny text-ink-light mt-1">{guide.subtitle}</p>
          </div>
          <span class="text-tiny text-ink-light">${guide.price}</span>
        </a>
      ))}
    </div>
  </section>

  <div class="mt-12"><RestaurantCallout /></div>
</Layout>
