---
import { mediaUrl } from "../lib/images";

interface Props {
  block: {
    id: string;
    image: { url: string; alt: string | null; filename: string; width: number | null; height: number | null } | null;
    caption: string | null;
  };
}

const { block } = Astro.props;
const src = block.image ? mediaUrl(block.image.filename || block.image.url) : null;
---

{src && (
  <figure class="my-8 rounded-2xl overflow-hidden">
    <img
      src={src}
      alt={block.image?.alt || block.caption || ""}
      class="w-full rounded-2xl"
      loading="lazy"
    />
    {block.caption && (
      <figcaption class="text-tiny text-ink-light mt-2 text-center">{block.caption}</figcaption>
    )}
  </figure>
)}
