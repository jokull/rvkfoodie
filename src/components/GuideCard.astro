---
interface Props {
  title: string;
  subtitle: string;
  description: string;
  price: number;
  slug: string;
  unlocked: boolean;
}

const { title, subtitle, description, price, slug, unlocked } = Astro.props;
---

<a
  href={`/guides/${slug}`}
  class="block border border-ink/10 rounded-2xl p-8 hover:border-ink/25 transition-colors group"
>
  <div class="flex items-start justify-between gap-4 mb-3">
    <h2 class="font-display text-[1.75rem] leading-tight group-hover:text-blue transition-colors">
      {title}
    </h2>
    {unlocked ? (
      <span class="text-tiny text-blue font-medium whitespace-nowrap mt-1">Unlocked</span>
    ) : (
      <span class="text-tiny text-ink-light whitespace-nowrap mt-1">${price}</span>
    )}
  </div>
  <p class="text-tiny leading-tiny text-ink-light mb-3">{subtitle}</p>
  <p class="text-ink-light">{description}</p>
</a>
