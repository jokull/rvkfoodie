---
import { getSiteSettings } from "../lib/cms";

const settings = await getSiteSettings();
---

<div class="border border-ink/10 rounded-2xl p-8">
  <p class="font-display text-[1.25rem] leading-tight mb-2">
    {settings.restaurantCalloutTitle}
  </p>
  <p class="text-ink-light text-tiny mb-4">
    {settings.restaurantCalloutText}
  </p>
  <a
    href={`mailto:${settings.restaurantCalloutEmail}`}
    class="text-tiny text-blue hover:opacity-80 transition-opacity"
  >
    {settings.restaurantCalloutEmail} &rarr;
  </a>
</div>
