---
interface Props {
  id?: string;
  name: string;
  address: string;
  description: string;
  note?: string;
  time?: string;
}

const { id, name, address, description, note, time } = Astro.props;

const mapsQuery = encodeURIComponent(`${name} ${address} Iceland`);
const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${mapsQuery}`;
---

<article class="py-8 border-b border-ink/5 last:border-0">
  {time && (
    <p class="text-tiny leading-tiny text-blue font-medium tracking-wide uppercase mb-2">
      {time}
    </p>
  )}
  <h3 class="font-display text-[1.75rem] leading-tight mb-1">
    {id ? (
      <a href={`/places/${id}`} class="hover:text-blue transition-colors">{name}</a>
    ) : name}
  </h3>
  {address && (
    <a
      href={mapsUrl}
      target="_blank"
      rel="noopener"
      class="text-tiny leading-tiny text-ink-light hover:text-blue transition-colors"
    >
      {address} &nearr;
    </a>
  )}
  <p class="mt-3">{description}</p>
  {note && (
    <p class="mt-2 text-tiny leading-tiny text-ink-light italic">{note}</p>
  )}
</article>
